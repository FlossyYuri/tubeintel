# Copiar para .env e preencher antes de fazer deploy
# cp .env.docker.example .env

# Obrigatório para funcionalidades YouTube
YOUTUBE_API_KEY=""

# Auth (opcional)
NEXTAUTH_URL="http://localhost:3005"
NEXTAUTH_SECRET=""

# Cache (opcional, valores em segundos)
CACHE_TTL_SEARCH=300
CACHE_TTL_TRENDING=3600
CACHE_TTL_CHANNEL=1800
CACHE_TTL_RISING=1800
